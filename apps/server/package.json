{
  "name": "@local-review/server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "DEV=1 node --watch-path=src --import tsx/esm src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:fsevents --external:lightningcss --external:*.node --external:vite --external:@anthropic-ai/claude-agent-sdk --inject:cjs-shim.js",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.69",
    "@hono/node-server": "^1.14.0",
    "chokidar": "^4.0.0",
    "hono": "^4.7.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.12.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.1",
    "globals": "^17.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.4.21"
  }
}
