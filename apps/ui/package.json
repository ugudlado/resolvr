{
  "name": "@local-review/ui",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "type-check": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest run --config vitest.config.unit.ts",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:watch": "vitest --config vitest.config.unit.ts",
    "test:ui": "vitest --ui --config vitest.config.unit.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.unit.ts",
    "test:coverage:ui": "vitest --coverage --ui --config vitest.config.unit.ts",
    "coverage": "vitest run --coverage --config vitest.config.unit.ts",
    "coverage:html": "vitest run --coverage --config vitest.config.unit.ts && open coverage/index.html",
    "lint": "eslint .",
    "format": "prettier --write src/**/*.{ts,tsx} tests/**/*.ts {tailwind.config.js,postcss.config.cjs,vite.config.ts}"
  },
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@git-diff-view/react": "^0.0.40",
    "@headless-tree/core": "^1.6.3",
    "@headless-tree/react": "^1.6.3",
    "@tiptap/extension-code-block-lowlight": "^3.20.0",
    "@tiptap/extension-heading": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-list": "^3.20.0",
    "@tiptap/extension-paragraph": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "highlight.js": "^11.11.1",
    "lowlight": "^3.3.0",
    "mdast-util-to-string": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "tiptap-markdown": "^0.9.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.3.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.47",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "typescript": "5.6.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.4.19",
    "vitest": "^3.2.4"
  }
}
