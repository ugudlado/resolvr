{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreExportsUsedInFile": true,
  "ignore": ["apps/ui/src/server/**"],
  "workspaces": {
    "apps/ui": {
      "entry": ["src/main.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/server": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    }
  }
}
