{
  "name": "local-review",
  "version": "2.0.7",
  "private": true,
  "type": "module",
  "scripts": {
    "type-check": "pnpm -C apps/vscode type-check",
    "lint": "pnpm -C apps/vscode type-check",
    "format": "prettier --write apps/vscode/src/**/*.ts",
    "prepare": "husky",
    "knip": "knip",
    "knip:fix": "knip --fix"
  },
  "lint-staged": {
    "apps/vscode/src/**/*.ts": [
      "pnpm -C apps/vscode exec eslint --no-warn-ignored",
      "prettier --write"
    ],
    "apps/**/*.{json,css,html}": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "knip": "^5.86.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.5.3",
    "typescript": "~5.8.3"
  }
}
