{
  "name": "local-review",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @local-review/server dev & pnpm --filter @local-review/ui dev",
    "dev:server": "pnpm --filter @local-review/server dev",
    "dev:ui": "pnpm --filter @local-review/ui dev",
    "build": "pnpm --filter @local-review/ui build",
    "start": "pnpm --filter @local-review/server start",
    "test:unit": "pnpm --filter @local-review/ui test:unit",
    "test:watch": "pnpm --filter @local-review/ui test:watch",
    "test:coverage": "pnpm --filter @local-review/ui test:coverage",
    "type-check": "pnpm --filter @local-review/ui type-check && pnpm --filter @local-review/server type-check",
    "lint": "pnpm --filter @local-review/ui lint",
    "format": "prettier --write apps/ui/src/**/*.{ts,tsx} apps/ui/*.{ts,js}",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/ui/src/**/*.{ts,tsx}": [
      "pnpm -C apps/ui exec eslint --no-warn-ignored",
      "prettier --write"
    ],
    "apps/**/*.{json,css,html}": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "~5.8.3"
  }
}
