{
  "name": "@todos/server",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:watch": "vitest watch --config vitest.unit.config.ts",
    "test:unit:coverage": "vitest run --config vitest.unit.config.ts --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest watch --config vitest.integration.config.ts",
    "test:all": "pnpm test:unit && pnpm test:integration",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ui": "vitest --coverage --ui",
    "coverage": "vitest run --coverage",
    "coverage:html": "vitest run --coverage && open coverage/index.html",
    "lint": "eslint .",
    "build": "node esbuild.config.js",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "tsx --watch --watch-preserve-output src/index.ts",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc"
  },
  "dependencies": {
    "@todos/schema": "workspace:*",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.15.5",
    "awilix": "^12.0.5",
    "axios": "^1.11.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "date-fns": "^3.6.0",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.39.1",
    "express": "^4.21.2",
    "jsdom": "^26.1.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.1.5",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "reflect-metadata": "^0.2.2",
    "ws": "^8.18.0",
    "zod": "^3.25.76",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.0.0",
    "@types/express": "^5.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "20.16.11",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "commander": "^14.0.0",
    "esbuild": "^0.25.9",
    "eslint": "^9.33.0",
    "express-jsdoc-swagger": "^1.8.0",
    "js-yaml": "^4.1.0",
    "ora": "^9.0.0",
    "supertest": "^7.1.4",
    "tdd-guard-vitest": "^0.1.5",
    "tsx": "^4.20.5",
    "typescript": "5.6.3",
    "vite": "^5.4.19",
    "vitest": "^3.2.4",
    "vitest-mock-extended": "^3.1.0"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8"
  }
}
